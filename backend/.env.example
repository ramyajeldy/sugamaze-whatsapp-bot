# Copy to .env and fill in. Get the API key from console.anthropic.com
# (this is the Developer Platform — separate from your Claude Pro subscription).
ANTHROPIC_API_KEY=sk-ant-...

# Model: Sonnet 4.6 is a good cost/quality default for grounded Q&A.
# For a cheaper, faster bot try claude-haiku-4-5-20251001.
CLAUDE_MODEL=claude-sonnet-4-6

# Get a free API key at voyageai.com
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3.5-lite
CHROMA_DIR=./chroma_data
TOP_K=5
MAX_DISTANCE=0.9
CHUNK_SIZE=400
CHUNK_OVERLAP=80

# WhatsApp (Meta Cloud API) — from developers.facebook.com / business.facebook.com
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Any string you make up; you'll enter the SAME value in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=sugamaze-verify-me
DEFAULT_TENANT_ID=sugamaze

# Escalation notifications (alert shop when bot can't answer)
ESCALATION_EMAIL=info@sugamaze.ca
ESCALATION_WHATSAPP_TO=14056557878

# Email (SMTP) — Gmail example
# For Gmail: generate an App Password at myaccount.google.com/apppasswords (not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
